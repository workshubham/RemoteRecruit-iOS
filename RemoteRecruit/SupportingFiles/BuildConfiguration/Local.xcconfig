// MARK: - API
// Local development: the RemoteRecruit Node backend on the Mac. The simulator
// reaches it directly on localhost.
SLASH = /
PROTOCOL_HTTP = http:$(SLASH)/

API_URL = $(PROTOCOL_HTTP)localhost:4000
API_ENVIRONMENT = Local
